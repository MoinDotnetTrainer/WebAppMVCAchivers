@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">

            <!-- Brand -->
            <a class="navbar-brand fw-bold" href="#">
                Accenture
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menu -->
            <div class="collapse navbar-collapse" id="navbarNav">

                <!-- Left Links -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" asp-action="Homepage" asp-controller="Users">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-action="CreateUser" asp-controller="Users">Create User</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-action="UsersData" asp-controller="Users">Display Users</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-action="First" asp-controller="StateManagement">State Management</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-action="Logout" asp-controller="Users">Logout</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-action="Logout" asp-controller="Users">Welcome Back: @HttpContextAccessor.HttpContext.Session.GetString("Mylogin")</a>
                    </li>
                </ul>

                <!-- Right Side -->
                <div class="d-flex">
                    <a href="#" class="btn btn-outline-light me-2">Login</a>
                    <a href="#" class="btn btn-primary">Sign Up</a>

                    </div>

            </div>
        </div>
    </nav>



    <!-- 🔥 Dynamic Content Area -->
    <main class="container my-5">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-3">
        <p class="mb-0">© 2026 MyLanding</p>
    </footer>

</body>
</html>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)