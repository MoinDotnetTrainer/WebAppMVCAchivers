@using MyProjectLibrary.Models
@model LoginModel

@{
    ViewData["Title"] = "Authenticate";
    Layout = null;
}



<!-- Bootstrap 5 CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        height: 100vh;
    }

    .login-card {
        border-radius: 15px;
    }
</style>

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 login-card" style="width: 400px;">

        <h3 class="text-center mb-4">Login</h3>

        <form method="post">

            <!-- Email -->
            <div class="mb-3">
                <label class="form-label">Email address</label>
                <input type="email" asp-for="Email" name="email" class="form-control" placeholder="Enter email" required />
            </div>

            <!-- Password -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" asp-for="Password" name="password" class="form-control" placeholder="Enter password" required />
            </div>



            <!-- Submit -->
            <div class="d-grid">
                <input type="submit" class="btn btn-primary" value="Login" />
                @TempData["ErrorMsg"]
            </div>

            <!-- Extra Links -->
            <div class="text-center mt-3">
                <a href="#">Forgot password?</a>
            </div>
            <!-- Extra Links -->
            <div class="text-center mt-3">
                <a asp-action="CreateUser">Create Account</a>
            </div>
        </form>
    </div>
</div>
